---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideContact from '../components/SideContact.astro';
import type { Locale } from '../i18n/dict';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}
const { locale, title, description } = Astro.props;
const htmlLang = locale === 'zh-CN' ? 'zh-Hans' : 'en';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'zh-CN' ? 'zh_CN' : 'en_US'} />
  </head>
  <body>
    <Header locale={locale} />
    <slot />
    <SideContact locale={locale} />
    <Footer locale={locale} />
  </body>
</html>
