---
/**
 * Home — EN (default locale).
 * Composes all 7 sections from the handoff HomeScreen.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import BrandWall from '../components/sections/BrandWall.astro';
import Categories from '../components/sections/Categories.astro';
import IndustriesServed from '../components/sections/IndustriesServed.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import GlobalSupply from '../components/sections/GlobalSupply.astro';
import QuickRFQSection from '../components/sections/QuickRFQSection.astro';

const locale = 'en' as const;
const title = 'AxisParts — Hong Kong industrial sourcing desk';
const description =
  'AxisParts supplies original parts from 1,000+ global brands. Confirmed quotes in 120 hours, shipped worldwide from Hong Kong.';
---

<BaseLayout locale={locale} title={title} description={description}>
  <main>
    <Hero locale={locale} />
    <BrandWall locale={locale} />
    <Categories locale={locale} />
    <IndustriesServed locale={locale} />
    <HowItWorks locale={locale} />
    <GlobalSupply locale={locale} />
    <QuickRFQSection locale={locale} />
  </main>
</BaseLayout>
