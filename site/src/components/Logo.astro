---
/** Logo placeholder — swap when client brand is final. */
interface Props {
  height?: number;
  color?: string;
  class?: string;
}
const { height = 26, color = 'currentColor', class: className } = Astro.props;
---

<svg
  viewBox="0 0 320 64"
  role="img"
  aria-label="Logo"
  height={height}
  style={`width:auto;display:block;color:${color};`}
  class:list={[className]}
>
  <rect x="0" y="14" width="120" height="36" rx="6" fill="none" stroke="currentColor" stroke-width="1.2"></rect>
  <text x="60" y="38" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="600" letter-spacing="3" fill="currentColor">LOGO</text>
</svg>
