---
/**
 * Side contact rail — fixed to the right edge (desktop only).
 * Phone · Email · WhatsApp · WeChat. Each tile reveals its value on hover.
 * Pure CSS interaction (no JS); hidden under 980px for now.
 */
import type { Locale } from '../i18n/dict';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const isEN = locale === 'en';

const phone = '+852 0000 0000';
const phoneHref = 'tel:+85200000000';
const email = 'sales@axisparts.hk';
const waHref = 'https://wa.me/85200000000';
const waLabel = 'WhatsApp';
const wechatLabel = isEN ? 'Scan to add on WeChat' : '扫码添加微信';
const wechatId = 'axisparts';
---

<aside class="side-contact" aria-label="Quick contact" data-side-contact>
  <a class="sc-item" href={phoneHref} aria-label={`Call ${phone}`}>
    <span class="sc-ico" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>'} />
    <span class="sc-pop">{phone}</span>
  </a>

  <a class="sc-item" href={`mailto:${email}`} aria-label={`Email ${email}`}>
    <span class="sc-ico" set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>'} />
    <span class="sc-pop">{email}</span>
  </a>

  <a class="sc-item" href={waHref} target="_blank" rel="noopener" aria-label="WhatsApp">
    <span class="sc-ico" set:html={'<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.8.37-.27.3-1.05 1.02-1.05 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.12-.27-.2-.57-.35z"/><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.46A10 10 0 1 0 12 2zm0 18.2c-1.5 0-2.96-.4-4.24-1.16l-.3-.18-2.85.87.85-2.78-.2-.32A8.2 8.2 0 1 1 12 20.2z"/></svg>'} />
    <span class="sc-pop">{waLabel}</span>
  </a>

  <div class="sc-item sc-wechat" tabindex="0" aria-label="WeChat">
    <span class="sc-ico" set:html={'<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8.69 4C4.98 4 2 6.46 2 9.5c0 1.73.97 3.27 2.49 4.29L4 16l2.2-1.1c.45.12.92.2 1.4.24-.06-.3-.1-.6-.1-.91 0-2.86 2.7-5.13 6-5.13.22 0 .43.01.64.03C13.7 6.06 11.42 4 8.69 4zm-2.2 3.2a.86.86 0 1 1 0 1.72.86.86 0 0 1 0-1.72zm4.4 0a.86.86 0 1 1 0 1.72.86.86 0 0 1 0-1.72z"/><path d="M22 14.23c0-2.5-2.46-4.53-5.5-4.53s-5.5 2.03-5.5 4.53 2.46 4.53 5.5 4.53c.6 0 1.18-.08 1.72-.23L20 19.7l-.46-1.5C21.06 17.34 22 15.88 22 14.23zm-7.3-1.1a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4zm3.6 0a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4z"/></svg>'} />
    <div class="sc-pop sc-pop--qr">
      <span class="sc-qr-title">{wechatLabel}</span>
      <span class="sc-qr" aria-hidden="true">QR</span>
      <span class="sc-qr-id">{wechatId}</span>
    </div>
  </div>
</aside>

<script>
  const rail = document.querySelector('[data-side-contact]');
  const hero = document.querySelector('.hero');
  if (rail && hero) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          rail.classList.toggle('is-visible', !entry.isIntersecting);
        }
      },
      { rootMargin: '-40% 0px 0px 0px' }
    );
    io.observe(hero);
  } else if (rail) {
    rail.classList.add('is-visible');
  }
</script>
