---
/**
 * Global supply — region list + freight modes, two columns.
 */
import SectionHeader from '../SectionHeader.astro';
import { home, type Locale } from '../../i18n/dict';
import { REGIONS, FREIGHT } from '../../data/catalogue';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = home[locale].globalSupply;
const isEN = locale === 'en';

/* Pictograms per freight mode — order matches FREIGHT (Air · Sea · Express). */
const FREIGHT_ICONS = [
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/><path d="M12 10v4"/><path d="M12 2v3"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>',
];
---

<section class="section soft" id="global-supply">
  <div class="wrap">
    <div class="section-top" data-reveal>
      <p class="section-lede">{t.lede}</p>
      <SectionHeader label={t.label} />
    </div>
    <div class="supply-cols">
      <div class="supply-left" data-reveal data-reveal-from="left">
        <div class="supply-block">
          <h4>{t.regions}</h4>
          <ul class="supply-list">
            {REGIONS.map((r, i) => (
              <li>
                <span class="m">{String(i + 1).padStart(2, '0')}</span>
                {isEN ? r.en : r.zh}
              </li>
            ))}
          </ul>
        </div>
        <div class="freight-row">
          {FREIGHT.map((f, i) => (
            <div class="freight-item">
              <span class="freight-ico" set:html={FREIGHT_ICONS[i]} />
              <span class="freight-label">{isEN ? f.en : f.zh}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="supply-media">
        <img
          src="/images/global_supply_last.jpg"
          alt="Worldwide freight network — air, sea and express"
          loading="lazy"
          data-reveal
          data-reveal-fade
        />
      </div>
    </div>
  </div>
</section>
