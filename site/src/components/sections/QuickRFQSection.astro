---
/**
 * Quick RFQ section — the navy wrapper around the React-island form.
 * Layout (intro left, form card right) stays in Astro so we don't ship
 * any extra JS for the static columns.
 */
import SectionHeader from '../SectionHeader.astro';
import QuickRFQ from './QuickRFQ.tsx';
import { home, type Locale } from '../../i18n/dict';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = home[locale].quickRFQ;
---

<section class="section" id="quick-rfq">
  <div class="wrap">
    <div class="rfq-grid">
      <div class="rfq-intro">
        <SectionHeader label={t.label} />
        <p class="sub">{t.sub}</p>
      </div>
      <QuickRFQ client:visible t={t} />
    </div>
  </div>
</section>
