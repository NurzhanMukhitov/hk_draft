---
/**
 * Site footer — 4 columns over navy. Gold hairlines top + bottom,
 * muted secondary text on navy.
 */
import { shared, type Locale } from '../i18n/dict';
import { localeRoot } from '../lib/paths';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = shared[locale].footer;
const homeHref = localeRoot(locale);
---

<footer class="site-foot">
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <a class="logo-placeholder logo-placeholder--foot" href={homeHref} aria-label="AxisParts home">LOGO HERE</a>
        <p class="tag" set:html={t.tag}></p>
      </div>
      <div class="foot-contact">
        <h4>{t.contact}</h4>
        <ul>
          {t.contactList.map((c) => <li>{c}</li>)}
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>{t.reg}</span>
    </div>
  </div>
</footer>
